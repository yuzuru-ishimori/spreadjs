{
  "hooks": {
    "PreToolUse": [
      { "matcher": "Edit|Write", "hooks": [
        { "type": "command", "command": "bash .claude/hooks/pre-edit-guard.sh", "timeout": 5 } ] }
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [
        { "type": "command", "command": "bash .claude/hooks/post-bash-dd-archive-reminder.sh", "timeout": 5 } ] }
    ]
  }
}
