# 依存とビルド成果物
node_modules/
dist/
build/

# DD-017 配布成果物（pack tarball closure＋manifest。scripts/release/build-release.sh が生成・再現可能）
# ルート直下の release/ のみ（非アンカーだと scripts/release/ 等も無視され release スクリプト本体が漏れる）
/release/

# TypeScript インクリメンタルビルド情報
*.tsbuildinfo

# Vite / Vitest のキャッシュ・カバレッジ
.vite/
coverage/

# ログ・OS 生成ファイル
*.log
.DS_Store
Thumbs.db

# Playwright MCP の一時出力（スナップショット・コンソールログ・スクリーンショット）
.playwright-mcp/

# dev-start.sh --showcase のデモ用ファイル永続化（oplog＋snapshot。リセットは削除でよい）
.dev-persistence/

# Playwright E2E の実行結果・レポート
test-results/
playwright-report/
.last-run.json
