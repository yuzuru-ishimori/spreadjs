// ==== packages/grid/src/diagnostics.ts ====
/** 診断エントリの重大度。 */
export type GridDiagnosticLevel = 'debug' | 'info' | 'warn' | 'error';
/** 診断エントリ（debug hook opt-in 時のみ生成）。 */
