{
  "name": "spreadjs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript製リアルタイム共同編集スプレッドシート型入力基盤（monorepo 骨格）",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npm run dev --workspace apps/playground",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:e2e": "playwright test --config apps/playground/playwright.config.ts",
    "test:e2e:showcase": "playwright test --config apps/showcase/playwright.config.ts",
    "test:invariants": "vitest run tests/invariants",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . && npm run lint:boundary",
    "lint:boundary": "node scripts/boundary/check.mjs",
    "consumer-harness": "bash scripts/consumer-harness.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "vite": "^6.4.3"
  }
}
