{
  "name": "@nanairo-sheet/grid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Canvas 描画グリッドの唯一の公開面（Facade・Experimental 0.x）。mount/destroy・GridEvent（接続状態・エラー通知）・lifecycle 契約。内部パッケージ（core/collab/render/selection/ime）を束ねるが再エクスポートしない（境界文書 §3・R7）。",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./test-support": "./src/test-support.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nanairo-sheet/core": "*",
    "@nanairo-sheet/types": "*",
    "@nanairo-sheet/collab": "*",
    "@nanairo-sheet/render": "*",
    "@nanairo-sheet/selection": "*",
    "@nanairo-sheet/ime": "*"
  }
}
