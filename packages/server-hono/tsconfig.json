{
  // server-hono はアダプター層（実 WS サーバー）。Node API（http/fs/timers）と ws/hono を使うため types:["node"]。
  // DOM は持ち込まない（lib は ES2022 のみ）。client-session コア（session/deps）は @nanairo-sheet/collab に env-free で存在。
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
