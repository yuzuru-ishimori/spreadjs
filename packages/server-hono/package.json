{
  "name": "@nanairo-sheet/server-hono",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "同期サーバーの唯一の公開面（Facade・Experimental 0.x）。Hono + @hono/node-server + ws で Room/Sequencer/PersistentRoom を配線し serve()/stop() を提供する。内部型（SnapshotData/RecoveryReport）を再エクスポートしない（R7）。",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/server.ts",
    "dev:integration": "tsx src/server.ts --integration"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nanairo-sheet/collab": "*",
    "@nanairo-sheet/core": "*",
    "@nanairo-sheet/server": "*",
    "@nanairo-sheet/types": "*",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2"
  }
}
