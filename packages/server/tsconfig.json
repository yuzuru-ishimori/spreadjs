{
  // server はシーケンサー・Room・Presence・スナップショットのコア。core と同じく
  // DOM/Node を持ち込まない（計画書 §17.2・ADR-022 ランタイム依存ゼロ）。lib は ES2022 のみ、
  // types:[] により @types/*（Node の crypto/timers 等）の暗黙取り込みも止め、環境非依存を強制する
  // （時刻は注入クロック、colorKey は決定的割当、connectionId は注入 IdGenerator）。
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": []
  },
  "include": ["src/**/*.ts"]
}
