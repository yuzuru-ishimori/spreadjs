# =============================================================================
# .dd-config — DD運用のパス設定（プロジェクト固有・単一ソース）
#
# 使い方: このファイルをプロジェクトルート直下に「.dd-config」の名前でコピーし、
#         値を実際のフォルダ配置に合わせる。
#
# 読み手: scripts/ 配下のDD系スクリプト（dd-index-gen.sh / dd-health.sh /
#         doc-check.sh / codex-review.sh）と .claude/hooks/（.agents/hooks/）のフック。
#         いずれも自己位置からプロジェクトルートを解決するため、どのディレクトリ
#         から実行しても本ファイルの設定が使われる（CWD非依存）。
#
# ⚠️ スクリプト本体にプロジェクト固有のパスを書かないこと。スクリプトは
#    dd-know-how からの上書き更新で差し替わる配布物であり、設定はこのファイル
#    だけが生き残る。
#
# 形式: KEY="value"（1行1キー）。⚠️ スクリプト/フックはこのファイルを source せず、
#       各キーの値だけを厳格抽出する（設定ファイル経由の任意コード実行を防ぐため）。
#       値に使える文字は英数・空白と ._:/~- のみ。$ ( ) ; ` 等を含む行は無視される。
#       パスはプロジェクトルートからの相対パスで、末尾スラッシュなし。
# =============================================================================

# アクティブDDの置き場所
DD_DIR="doc/DD"

# アーカイブ済みDDの置き場所（実レイアウトに合わせる。例: doc/DD/archive）
ARCHIVE_DIR="doc/archived/DD"

# doc-check.sh が走査するドキュメントルート（DOC-MAP.md のある場所）
DOC_DIR="doc"

# （任意）dd-update.sh が参照する dd-know-how の場所。
# 省略時はプロジェクトの兄弟ディレクトリ ../dd-know-how を使う
# SOURCE_REPO="C:/repo/dd-know-how"

# （任意）テンプレートフォルダ。省略時は doc/templates → docs/templates →
# templates の順に dd_template.md の実在で自動検出する
# TEMPLATES_DIR="doc/templates"
